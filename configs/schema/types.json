{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string"
        }
    },
    "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "python_class_name": {
                    "type": "string"
                }
            },
            "required": [
                "type",
                "description",
                "python_class_name"
            ],
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}