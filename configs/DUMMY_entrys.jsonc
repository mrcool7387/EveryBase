{
    "$schema": "./schema/entrys.json",

    "field_id": {
        "field_type": "field_id", // Type of the Field, from an Internal Type or Custom Type (e.g. "dcls")
        "required": true, // Whether this field is required to fill
        "unique": true, // Whether the value of this field must be unique across all entries
        "default": null // Default value for this field
    }
}